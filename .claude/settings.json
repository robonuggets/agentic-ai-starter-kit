{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "model": "claude-sonnet-4-6",
  "permissions": {
    "deny": [
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~/*)",
      "Bash(rm -rf $HOME*)",
      "Bash(rm -rf .)",
      "Bash(rm -rf ./*)",
      "Bash(rm -rf *)",
      "Bash(sudo rm:*)",
      "Bash(:(){ :|:& };:)",
      "Bash(dd if=*)",
      "Bash(mkfs:*)",
      "Bash(format:*)",
      "Bash(shutdown:*)",
      "Bash(reboot:*)",
      "Bash(halt:*)",
      "Bash(poweroff:*)",
      "Bash(killall:*)",
      "Bash(chmod -R 777 /*)",
      "Bash(chown -R:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git push origin main --force:*)",
      "Bash(git push origin master --force:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -fd:*)",
      "Bash(git clean -fdx:*)",
      "Bash(git checkout --:*)",
      "Bash(git branch -D main)",
      "Bash(git branch -D master)",
      "Bash(git filter-branch:*)",
      "Bash(git update-ref -d:*)",
      "Bash(npm publish:*)",
      "Bash(npm unpublish:*)",
      "Bash(pip uninstall -y:*)",
      "Bash(curl * | sh)",
      "Bash(curl * | bash)",
      "Bash(wget * | sh)",
      "Bash(wget * | bash)",
      "Bash(eval:*)",
      "Bash(history -c)",
      "Bash(history -w)",
      "Bash(unset PATH)",
      "Bash(export PATH=)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/id_rsa)",
      "Read(**/id_ed25519)",
      "Read(**/.ssh/**)",
      "Read(**/.aws/credentials)",
      "Read(**/.npmrc)"
    ],
    "allow": [
      "Bash(ls:*)",
      "Bash(pwd)",
      "Bash(cd:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(echo:*)",
      "Bash(which:*)",
      "Bash(type:*)",
      "Bash(file:*)",
      "Bash(date:*)",
      "Bash(whoami)",
      "Bash(hostname)",
      "Bash(uname:*)",
      "Bash(env)",
      "Bash(git status)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git branch)",
      "Bash(git branch -a)",
      "Bash(git remote -v)",
      "Bash(git show:*)",
      "Bash(git config --get:*)",
      "Bash(git config --list)",
      "Bash(git rev-parse:*)",
      "Bash(git ls-files:*)",
      "Bash(git blame:*)",
      "Bash(npm --version)",
      "Bash(npm list:*)",
      "Bash(npm ls:*)",
      "Bash(npm outdated:*)",
      "Bash(npm run test:*)",
      "Bash(npm test)",
      "Bash(npm test:*)",
      "Bash(node --version)",
      "Bash(node -v)",
      "Bash(python --version)",
      "Bash(python3 --version)",
      "Bash(pip list)",
      "Bash(pip show:*)",
      "Bash(pip --version)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(find:*)",
      "Bash(tree:*)",
      "Bash(du:*)",
      "Bash(df:*)",
      "Bash(ps:*)",
      "Bash(top -n 1)",
      "Bash(curl -s:*)",
      "Bash(curl -sI:*)",
      "Bash(curl --version)",
      "Bash(wget --version)",
      "Bash(jq:*)",
      "Bash(diff:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(awk:*)",
      "Bash(sed -n:*)",
      "Bash(test -f:*)",
      "Bash(test -d:*)",
      "Bash(test -e:*)",
      "Read(**)",
      "Glob(**)",
      "Grep(**)"
    ]
  }
}
